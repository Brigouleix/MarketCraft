# Base de données MySQL
DB_HOST=localhost
DB_NAME=marketcraft
DB_USER=root
DB_PASS=secret
DB_CHARSET=utf8mb4

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_string_at_least_32_chars
JWT_TTL=86400

# Application
APP_URL=https://api.marketcraft.local
APP_ENV=development

# CORS – mettre * en dev, ou une liste séparée par virgules en prod
# Ex : https://marketcraft.com,https://www.marketcraft.com
ALLOWED_ORIGINS=*
